# ──────────────────────────────────────────────
# .env.local  —  로컬 개발용 환경 변수
# 이 파일을 .gitignore에 추가하고 절대 커밋하지 마세요!
# ──────────────────────────────────────────────

# ── [필수] OpenAI API 키 ──
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── [선택] 이메일 발송: Resend ──
# https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── [선택] 리드 DB: Supabase ──
# https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── [선택] Notion 데이터베이스 ──
# https://developers.notion.com
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── [선택] Airtable ──
AIRTABLE_API_KEY=patxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxxxx

# ── 앱 설정 ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
